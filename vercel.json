{
  "cleanUrls": true,
  "redirects": [
    { "source": "/client_feedback/:path*", "destination": "/", "permanent": false },
    { "source": "/feedback/:path*", "destination": "/", "permanent": false },
    { "source": "/category/:path*", "destination": "/", "permanent": false },
    { "source": "/services/saas-sales", "destination": "/services/go-to-market-strategy", "permanent": true },
    { "source": "/he/services/saas-sales", "destination": "/he/services/go-to-market-strategy", "permanent": true },
    { "source": "/services/contract-negotiation", "destination": "/services/fractional-cro", "permanent": true },
    { "source": "/he/services/contract-negotiation", "destination": "/he/services/fractional-cro", "permanent": true },
    { "source": "/services/global-markets", "destination": "/services/market-entry", "permanent": true },
    { "source": "/he/services/global-markets", "destination": "/he/services/market-entry", "permanent": true }
  ],
  "rewrites": [
    { "source": "/wp-admin/:path*", "destination": "/api/gone" },
    { "source": "/wp-content/:path*", "destination": "/api/gone" },
    { "source": "/wp-includes/:path*", "destination": "/api/gone" },
    { "source": "/wp-login.php", "destination": "/api/gone" },
    { "source": "/xmlrpc.php", "destination": "/api/gone" }
  ]
}
